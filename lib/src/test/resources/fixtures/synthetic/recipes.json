    "recipeIngredient": [
      "1 tbsp olive oil",
      "1 onion, diced",
      "2 carrots, diced",
      "2 celery stalks, diced",
      "3 cloves garlic, minced",
      "1 1/2 cups brown lentils, rinsed",
      "1 can (400 g) diced tomatoes",
      "5 cups vegetable broth",
      "1 tsp cumin",
      "1 tsp smoked paprika",
      "1 bay leaf",
      "Salt and pepper",
      "1 tbsp lemon juice"
    ],
    "recipeInstructions": [
      {
        "@type": "HowToSection",
        "name": "Saute",
        "itemListElement": [
          {
            "@type": "HowToStep",
            "text": "Set pressure cooker to Sauté. Add oil, then onion, carrot, celery; cook 5 minutes."
          },
          {
            "@type": "HowToStep",
            "text": "Add garlic and spices; cook 30 seconds."
          }
        ]
      },
      {
        "@type": "HowToSection",
        "name": "Pressure cook",
        "itemListElement": [
          {
            "@type": "HowToStep",
            "text": "Add lentils, tomatoes, broth, and bay leaf. Seal and cook on High Pressure for 12 minutes."
          },
          {
            "@type": "HowToStep",
            "text": "Natural release 10 minutes, then quick release remaining pressure."
          }
        ]
      },
      {
        "@type": "HowToSection",
        "name": "Finish",
        "itemListElement": [
          {
